# ========================================
# AegisNet Environment Configuration
# ========================================

# --- Local Model (Ollama) ---
OLLAMA_BASE_URL=http://localhost:11434

# --- Routing ---
# Options: auto, cost_optimized, performance, quality
DEFAULT_ROUTING_STRATEGY=auto
DEFAULT_MODEL=local/llama3

# --- Database ---
DATABASE_URL=sqlite+aiosqlite:///./aegisnet.db

# --- Server ---
BACKEND_PORT=8000
FRONTEND_PORT=5173

# --- Security ---
API_SECRET_KEY=change-me-to-a-random-secret
